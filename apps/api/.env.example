# ============================================================================
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.
# Never commit real credentials.
# ============================================================================

# ----------------------------------------------------------------------------
# LOCAL DEVELOPMENT — connect to Cloud SQL via the Cloud SQL Auth Proxy.
# ----------------------------------------------------------------------------
# 1. Start the proxy in a separate terminal (listens on 127.0.0.1:5432):
#
#       cloud-sql-proxy <INSTANCE_CONNECTION_NAME> --port 5432
#
#    where <INSTANCE_CONNECTION_NAME> looks like:  my-project:asia-east1:device-db
#
# 2. The app then connects to the proxy on localhost — host is 127.0.0.1 but
#    traffic is securely tunneled to Cloud SQL.
#
DATABASE_URL="postgresql://<DB_USER>:<DB_PASSWORD>@127.0.0.1:5432/<DB_NAME>?schema=public"

# Convenience value for starting the proxy (project:region:instance).
INSTANCE_CONNECTION_NAME="<project>:<region>:<instance>"

# ----------------------------------------------------------------------------
# PRODUCTION (Cloud Run) — connect to Cloud SQL via Unix socket.
# ----------------------------------------------------------------------------
# When deploying to Cloud Run, attach the Cloud SQL instance to the service
# (--add-cloudsql-instances <INSTANCE_CONNECTION_NAME>) and inject DATABASE_URL
# as an env var / secret in this form (note: host points at the socket dir):
#
#   DATABASE_URL="postgresql://<DB_USER>:<DB_PASSWORD>@localhost/<DB_NAME>?host=/cloudsql/<INSTANCE_CONNECTION_NAME>&schema=public"
#
# Do NOT store production credentials here — use Secret Manager / Cloud Run env.